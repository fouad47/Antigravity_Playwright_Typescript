{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@components/*": ["src/components/*"],
      "@utils/*": ["src/utils/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@api/*": ["src/api/*"],
      "@helpers/*": ["src/helpers/*"],
      "@test-data/*": ["test-data/*"],
      "@config/*": ["config/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "chapters/**/*.ts",
    "config/**/*.ts",
    "test-data/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
